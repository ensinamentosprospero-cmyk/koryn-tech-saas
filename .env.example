# Supabase — copie do dashboard (Connect ou Settings → API + Database)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
DATABASE_URL=postgres://postgres.xxxxx:senha@aws-1-sa-east-1.pooler.supabase.com:6543/postgres
DATABASE_SSL=false

# --- Servidor ---
NODE_ENV=development
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio
SERVE_STATIC=false
STORE_DB_PATH=server/data/store.db

# --- Frontend ---
VITE_TENANT_BASE_DOMAINS=localhost
VITE_API_BASE_URL=/api

# --- Cobrança ---
BILLING_PROVIDER=manual
